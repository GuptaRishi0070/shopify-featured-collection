<div class="collection-wrapper">

  {% if section.settings.heading != blank %}
    <h2 class="section-heading">{{ section.settings.heading }}</h2>
  {% endif %}

  {% for block in section.blocks %}
    {% assign collection = collections[block.settings.collection] %}

    {% if collection %}
      <div class="collection-section" {{ block.shopify_attributes }}>
        
        <h3 class="collection-title">{{ collection.title }}</h3>

        <div 
          class="product-grid"
          data-handle="{{ collection.handle }}"
        >
          <div class="loader">Loading products...</div>
        </div>

      </div>
    {% endif %}
  {% endfor %}

</div>


<style>
.collection-wrapper {
  padding: 40px 16px;
}

.section-heading {
  text-align: center;
  margin-bottom: 24px;
}

.collection-title {
  font-size: 18px;
  margin-bottom: 12px;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}


@media (max-width: 1024px) {
  .product-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}


@media (max-width: 768px) {
  .product-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
}


@media (max-width: 480px) {
  .product-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }
}

.product-card {
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid #eee;
  background: #fff;
}

.product-image-wrapper {
  position: relative;
  aspect-ratio: 1 / 1;
}

.product-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}


.badge.featured {
  position: absolute;
  top: 10px;
  left: 10px;
  background: #ff3b30;
  color: #fff;
  font-size: 11px;
  padding: 6px 12px;
  border-radius: 999px;
  font-weight: 600;
}


.product-info {
  padding: 10px;
}

.product-title {
  font-size: 13px;
  margin-bottom: 4px;

  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.price {
  font-size: 14px;
  font-weight: 600;
}

/* STATES */
.loader,
.empty-state {
  grid-column: 1 / -1;
  text-align: center;
  padding: 20px;
  font-size: 14px;
}
</style>


<script>
(function () {

  const grids = document.querySelectorAll(".product-grid");

  if (!grids.length) return;

  function renderProducts(container, products) {

    const featured = products
      .filter(p => p.tags.includes("featured"))
      .slice(0, 5);

    if (!featured.length) {
      container.innerHTML = `<div class="empty-state">No featured products</div>`;
      return;
    }

    container.innerHTML = "";

    featured.forEach(product => {

      const image = product.images?.[0]?.src || "";
      const price = product.variants?.[0]?.price || "";

      const html = `
        <div class="product-card">
          <div class="product-image-wrapper">
            <img src="${image}" alt="${product.title}" class="product-image" loading="lazy">
            <span class="badge featured">FEATURED</span>
          </div>

          <div class="product-info">
            <div class="product-title">${product.title}</div>
            <div class="price">₹${price}</div>
          </div>
        </div>
      `;

      container.insertAdjacentHTML("beforeend", html);
    });
  }

  function loadProducts(container, handle) {
    fetch(`/collections/${handle}/products.json`)
      .then(res => res.json())
      .then(data => renderProducts(container, data.products))
      .catch(() => {
        container.innerHTML = `<div class="empty-state">Failed to load</div>`;
      });
  }

  grids.forEach(grid => {
    const handle = grid.dataset.handle;
    loadProducts(grid, handle);
  });

})();
</script>


{% schema %}
{
  "name": "Custom Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    }
  ],
  "blocks": [
    {
      "type": "collection_block",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Custom Section"
    }
  ]
}
{% endschema %}